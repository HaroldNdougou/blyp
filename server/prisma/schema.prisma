generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid())
  phone               String              @unique
  balanceFcfa         Int                 @default(0)
  /// Hash scrypt (jamais le PIN en clair) — null tant que l’onboarding n’a pas défini le PIN.
  transactionPinHash  String?
  firstName           String?
  lastName            String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  transactions        Transaction[]
  notifications       UserNotification[]
}

/// Notifications in-app (titres / corps définis uniquement côté serveur — jamais de texte arbitraire client).
model UserNotification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String    @db.VarChar(64)
  title     String    @db.VarChar(160)
  body      String    @db.VarChar(500)
  emoji     String?   @db.VarChar(16)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
}

model OtpChallenge {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

/// Chaque envoi SMS OTP réussi (inscription + renvoi) — audit en base.
model OtpSendLog {
  id        String   @id @default(cuid())
  phone     String
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
}

/// Clics « Say Hello » — horodatage serveur (UTC) pour chaque enregistrement.
model HelloLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  @@index([createdAt])
}

enum TxType {
  DEPOSIT
  PAYMENT
}

model Transaction {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              TxType
  amountFcfa        Int
  counterpartyName  String?
  counterpartyPhone String?
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
}
