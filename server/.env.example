# Tu peux copier ce fichier en server/.env ou tout mettre dans le .env à la racine du repo (voir server/src/loadEnv.js).
# Si l’API tourne uniquement sur Railway : mets les mêmes variables dans Railway (Variables du service),
# pas besoin d’un server/.env local pour la prod. ANDROID_SMS_OTP_APP_HASH s’ajoute aussi sur Railway.
# Postgres (local : docker compose up -d db, puis URL ci-dessous)
DATABASE_URL="postgresql://blyp:blyp@localhost:5432/blyp"
JWT_SECRET="replace-with-long-random-secret"
OTP_PEPPER="replace-with-random-pepper"
# Pepper dédié au hash du PIN transaction (défaut = OTP_PEPPER si absent)
# TRANSACTION_PIN_PEPPER="replace-with-random-pepper-pin"
PORT=3001
NODE_ENV=development

# --- Rechargement wallet (cash-in)
# sync (défaut) : crédit immédiat après PIN + une transaction DB (rapide, sans PawaPay).
# async : appelle POST https://api.sandbox.pawapay.io/v2/deposits puis attend callback ou polling GET /v2/deposits/{depositId}.
# DEPOSIT_MODE=sync
# DEPOSIT_MIN_FCFA=1
# DEPOSIT_MAX_FCFA=500000
#
# --- PawaPay (sandbox : https://docs.pawapay.io/v2/docs/how_to_start — jeton API dashboard)
# Requis si DEPOSIT_MODE=async
# PAWAPAY_API_TOKEN="votre-jeton-sandbox"
# PAWAPAY_API_BASE_URL=https://api.sandbox.pawapay.io
# PAWAPAY_DEPOSIT_CURRENCY=XAF
# Fournisseur par défaut si le numéro ne permet pas l’heuristique 69… → Orange
# PAWAPAY_DEFAULT_MM_PROVIDER=MTN_MOMO_CMR
#
# Callback HTTPS configuré dans le dashboard PawaPay → POST vers ton API, ex. :
#   https://ton-domaine/webhooks/pawapay/deposit
# Corps JSON = callback « V2Deposit » (depositId, status COMPLETED|FAILED|PROCESSING).
# Vérification optionnelle : none = accepter les POST PawaPay (sandbox / confiance TLS).
# hmac = en-tête X-Pawapay-Signature = HMAC-SHA256 hex du corps brut (tests curl uniquement).
# PAWAPAY_WEBHOOK_VERIFY=none
# PAWAPAY_WEBHOOK_SECRET="secret-si-hmac"

# --- SMS (OTP réels) : choisir UNE option. En local sans rien, le code OTP s’affiche dans les logs.
# Optionnel : forcer le fournisseur (sinon détection auto) : obitsms | africastalking | webhook | twilio
# SMS_PROVIDER=obitsms

# 1) Obit SMS — API v2 GET (doc obitsms.com) : key_api + sender + destination (237 + 9 chiffres)
# OBIT_SMS_KEY_API="ta-clé-api"
# OBIT_SMS_SENDER="TESTAPI"   # expéditeur validé chez Obit (comme dans leur exemple)
# Optionnel si l’URL change : OBIT_SMS_BASE_URL="https://obitsms.com/api/v2/bulksms"

# 2) Africa’s Talking — https://africastalking.com
# AFRICASTALKING_USERNAME="sandbox" ou ton username prod
# AFRICASTALKING_API_KEY="atsk_..."
# Optionnel : expéditeur / shortcode enregistré chez eux
# AFRICASTALKING_SENDER_ID=""
# Sandbox : AFRICASTALKING_API_HOST=api.sandbox.africastalking.com (voir doc AT)

# 3) Webhook : ton propre service reçoit POST JSON { "to": "+237...", "message": "..." }
# SMS_WEBHOOK_URL="https://ton-api.com/send-sms"
# SMS_WEBHOOK_BEARER_TOKEN="secret-optionnel"

# 4) Twilio (optionnel)
# TWILIO_ACCOUNT_SID="ACxxxxxxxx"
# TWILIO_AUTH_TOKEN="xxxxxxxx"
# TWILIO_PHONE_NUMBER="+1..."
# TWILIO_MESSAGING_SERVICE_SID="MGxxxxxxxx"

# --- Auto-saisie OTP Android (Google SMS Retriever) — optionnel
# 11 car. par hash ; plusieurs : HASH_DEBUG,HASH_RELEASE (build local vs Play / EAS).
# Obtenir le hash debug : à la racine du repo, `npm run android:sms-hash` (JDK keytool + debug.keystore).
# Ou log Metro sur l’écran OTP : [Blyp] ANDROID_SMS_OTP_APP_HASH=...
# ANDROID_SMS_OTP_APP_HASH=xxxxxxxxxxx
