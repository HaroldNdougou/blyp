# --- App Expo (racine du repo) ---
# Vide = mode démo (aucun SMS réel). L’URL est lue via app.config.js + extra.
# Émulateur Android : http://10.0.2.2:3001 — Téléphone USB : `npm run android:usb` puis http://127.0.0.1:3001
# Après modification : rebuild natif (ex. npx expo run:android) pour usesCleartextTraffic si http://
EXPO_PUBLIC_API_URL=

# --- API Blyp (lus aussi par le serveur si tu lances `npm run dev` dans server/) ---
# Copie ce fichier vers `.env` à la racine puis remplis les valeurs (ne commite pas `.env`).

# Postgres local (service `db` du docker-compose, ou uniquement `docker compose up -d db`)
DATABASE_URL=postgresql://blyp:blyp@localhost:5432/blyp

JWT_SECRET=change-moi-long-secret-local
OTP_PEPPER=change-moi-pepper-local

# SMS Obit (même variables que sur Railway)
SMS_PROVIDER=obitsms
OBIT_SMS_KEY_API=
OBIT_SMS_SENDER=
# OBIT_SMS_BASE_URL=https://obitsms.com/api/v2/bulksms

NODE_ENV=development
